{
  "name": "steam-bridge-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build -w steam-bridge",
    "check:platform": "node scripts/assert-apple-silicon-target.cjs",
    "typecheck": "npm run typecheck -w steam-bridge",
    "native:build": "cargo build -p steam-bridge-native --release --target aarch64-apple-darwin && npm run native:link -w steam-bridge -- --target aarch64-apple-darwin",
    "native:check": "cargo check -p steam-bridge-native --target aarch64-apple-darwin",
    "native:fmt": "cargo fmt --all --check",
    "native:link": "npm run native:link -w steam-bridge",
    "test": "npm run typecheck && npm run test:unit",
    "test:unit": "npm run build && node --test tests/steam-bridge.test.cjs"
  },
  "devDependencies": {
    "@emnapi/runtime": "1.11.1",
    "@napi-rs/cli": "3.7.2",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.13"
  }
}
