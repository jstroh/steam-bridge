{
  "name": "steam-bridge-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build -w steam-bridge",
    "typecheck": "npm run typecheck -w steam-bridge",
    "native:build": "cargo build -p steam-bridge-native --release && npm run native:link -w steam-bridge",
    "native:check": "cargo check -p steam-bridge-native",
    "native:fmt": "cargo fmt --all --check",
    "native:link": "npm run native:link -w steam-bridge",
    "test": "npm run typecheck && npm run native:check"
  },
  "devDependencies": {
    "@napi-rs/cli": "2.18.4",
    "typescript": "5.5.3"
  },
  "engines": {
    "node": ">=18"
  }
}

