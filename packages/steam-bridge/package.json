{
  "name": "steam-bridge",
  "version": "0.1.4",
  "description": "Native-backed Steamworks bridge for Electron and Node.",
  "license": "MIT",
  "homepage": "https://github.com/jstroh/steam-bridge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jstroh/steam-bridge.git",
    "directory": "packages/steam-bridge"
  },
  "bugs": {
    "url": "https://github.com/jstroh/steam-bridge/issues"
  },
  "keywords": [
    "steam",
    "steamworks",
    "electron",
    "node",
    "native-addon",
    "napi-rs",
    "macos",
    "windows",
    "linux",
    "apple-silicon"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "steam-bridge-init-client-txn": "bin/init-client-txn.cjs",
    "steam-bridge-prepare-macos-app": "bin/prepare-macos-app.cjs",
    "steam-bridge-validate-checkout-target": "bin/validate-checkout-target.cjs",
    "steam-bridge-verify-macos-signing": "bin/verify-macos-signing.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./electron": {
      "types": "./dist/electron.d.ts",
      "default": "./dist/electron.js"
    },
    "./electron-builder": {
      "types": "./dist/electron-builder.d.ts",
      "default": "./dist/electron-builder.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "templates",
    "*.node",
    "!steam_bridge_native.local.node",
    "libsteam_api.*",
    "libsdkencryptedappticket.*",
    "steam_api*.dll",
    "sdkencryptedappticket*.dll",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "napi": {
    "binaryName": "steam_bridge_native",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "native:link": "node scripts/link-native.cjs"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "electron": ">=24"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
