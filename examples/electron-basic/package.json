{
  "name": "steam-bridge-electron-example",
  "private": true,
  "version": "0.2.13",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package": "node ../../scripts/package-electron-example.cjs",
    "package:mac": "node ../../scripts/package-electron-example.cjs --target aarch64-apple-darwin",
    "package:linux": "node ../../scripts/package-electron-example.cjs --target x86_64-unknown-linux-gnu",
    "package:win": "node ../../scripts/package-electron-example.cjs --target x86_64-pc-windows-msvc"
  },
  "dependencies": {
    "electron": "43.1.1",
    "steam-bridge": "file:../../packages/steam-bridge"
  }
}
